@using MyTaskManager.Models.ViewModels
@model TaskVM

<form method="post">
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary">Add new Task</h2>
            </hr>
        </div>
        <div class="mb-3 row p-1">
            <label asp-for="Title" class="p-0"></label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="texr-danger"></span>
        </div>
        <div class="mb-3 row p-1">
            <label asp-for="Description" class="p-0"></label>
            <input asp-for="Description" class="form-control" />
            <span asp-validation-for="Description" class="texr-danger"></span>

        </div>
        <div class="mb-3 row p-1">
            <label asp-for="DueDate" class="p-0"></label>
            <input asp-for="DueDate" class="form-control" />
            <span asp-validation-for="DueDate" class="texr-danger"></span>
        </div>
        <div class="mb-3 row p-1">
            <label asp-for="Priority" class="p-0"></label>
            <select asp-for="Priority" class="form-control" asp-items="Html.GetEnumSelectList<MyTaskManager.Models.PriorityEnum>()"></select>
            <span asp-validation-for="Priority" class="texr-danger"></span>
        </div>
        <div class="mb-3 row p-1">
            <label asp-for="CategoryId" class="p-0"></label>
            <input asp-for="CategoryId" class="form-control" />
            <span asp-validation-for="CategoryId" class="texr-danger"></span>
        </div>
        <div class="row">
            <div class="col-6 col-md-3">
                <button type="submit" class="btn btn-primary form-control">Add</button>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Task" asp-action="Index" class="btn btn-outline-secondary form-control">
                    Back to Task list
                </a>
            </div>
        </div>


    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}