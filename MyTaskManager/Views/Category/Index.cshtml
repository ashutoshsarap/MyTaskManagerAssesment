@using MyTaskManager.Models.ViewModels
@model IEnumerable<CategoryVM>

@{
    ViewData["Title"] = "Categories";
}

<div class="col-6 text-end">
    <a asp-action="Add" class="btn btn-primary">
        <i class="bi bi-file-plus"></i>Add new Category
    </a>
</div>

<h1>Tasks</h1>

@if (Model == null || !Model.Any())
{
    <p>No tasks available.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Category Name</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td>@c.Name</td>

                    <td>
                        <div class="w-75 btn-group" role="group">
                            <form asp-controller="Category" asp-action="Delete" asp-route-id="@c.Id" class="btn btn-primary mx-2">
                                <button type="submit" class="btn-danger">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}